# ============================================
# Job Copilot — Variables d'environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs.
# cp .env.local.example .env.local

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-side only) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Indeed MCP ---
INDEED_MCP_URL=https://your-indeed-mcp-endpoint
INDEED_MAX_CALLS_PER_MINUTE=10   # optionnel
INDEED_TIMEOUT_MS=10000           # optionnel